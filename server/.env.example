# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=bharosa

# Server
PORT=8000

# LLM provider keys (any subset works; the layer falls back across providers).
# Each may be a single key or a JSON array of keys, e.g. ["key1","key2"]
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
COHERE_API_KEY=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
MISTRAL_API_KEY=

# Groq model defaults
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# Voice (Sensor 2)
ELEVENLABS_API_KEY=
